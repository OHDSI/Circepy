{#
  T-SQL template for phenotype evaluation rubrics.
  Compatible with SQLRender.
#}

-- Phenotype Evaluation: {{ rubric.name }}
-- Target: {{ rubric.target_phenotype }}
-- Ruleset ID: {{ rubric.ruleset_id }}
-- Generated by circe.evaluation

WITH cohort AS (
    SELECT person_id, cohort_start_date AS index_date
    FROM @cohort_table
    WHERE cohort_definition_id = @cohort_id
{% if top_n %}
    ORDER BY cohort_start_date 
    OFFSET 0 ROWS FETCH NEXT @top_n ROWS ONLY
{%- endif %}
)
{%- for rule in rubric.rules %}
,
rule_{{ rule.rule_id }} AS (
    -- Rule {{ rule.rule_id }}: {{ rule.name }}
    SELECT 
        c.person_id, 
        c.index_date,
        CASE 
            WHEN EXISTS (
                SELECT 1 
                FROM @cdm_schema.{{ domains[rule.domain].table }} t
                WHERE t.{{ domains[rule.domain].person_column }} = c.person_id
                  AND t.{{ domains[rule.domain].concept_column }} IN ({{ rule.concept_ids | join(', ') }})
                  AND t.{{ domains[rule.domain].date_column }} BETWEEN DATEADD(day, {{ rule.window_start_days }}, c.index_date) 
                                                                 AND DATEADD(day, {{ rule.window_end_days }}, c.index_date)
                  {%- if rule.domain == "measurement" and rule.value_threshold is not none and rule.value_operator %}
                  AND t.{{ domains[rule.domain].value_column }} {{ operators[rule.value_operator] }} {{ rule.value_threshold }}
                  {%- endif %}
            ) THEN 1 
            ELSE 0 
        END AS matched
    FROM cohort c
)
{%- endfor %}

-- Output: Normalized rule results (one row per subject per rule)

{%- for rule in rubric.rules %}
SELECT 
    {{ rubric.ruleset_id }} AS ruleset_id, 
    c.person_id AS subject_id, 
    {{ rule.rule_id }} AS rule_id, 
    CASE WHEN r.matched = 1 THEN {{ rule.weight }} ELSE 0 END AS score
FROM cohort c 
JOIN rule_{{ rule.rule_id }} r ON c.person_id = r.person_id
{% if not loop.last %}
UNION ALL
{% endif %}
{%- endfor -%}
;

{% if include_aggregation -%}
