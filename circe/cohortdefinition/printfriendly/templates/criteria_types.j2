  condition occurrence{% if isPlural and not c.first %}s{% endif %} of {{ codeset_name(c.codeset_id, "any condition") -}}
  {% if c.condition_source_concept is not none %} (including {{ codeset_name(c.condition_source_concept, "any condition") }} source concepts){% endif -%}
  {%- if c.first %} for the first time in the person's history{% endif -%}
  {%- if attrs|length > 0 -%}, {{ attrs|join("; ") }}{%- endif -%}
  {%- if c.correlated_criteria -%}; {{ Group(c.correlated_criteria, level, indexLabel=codeset_name(c.codeset_id, "any condition")) }}{%- else -%}.{%- endif -%}
{%- endmacro -%}

{%- macro DrugExposure(c, level, isPlural=true, countCriteria={}, indexLabel="cohort entry") -%}
  {%- set attrs = [] -%}
  {%- if countCriteria and countCriteria.occurrence -%}
    {%- set temp = WindowCriteria(countCriteria, indexLabel) -%}
    {%- if temp -%}{%- set _ = attrs.append(temp) -%}{%- endif -%}
  {%- endif -%}
  
  {%- set temp = AgeGenderCriteria(age_at_start=c.age, gender=c.gender, gender_cs=c.gender_cs) -%}
  {%- if temp -%}{%- set _ = attrs.append(temp) -%}{%- endif -%}
  
  {%- set temp = inputTypes.DateAdjustment(c.date_adjustment) -%}
  {%- if temp -%}{%- set _ = attrs.append(temp) -%}{%- endif -%}
  
  {%- set temp = EventDateCriteria(c.occurrence_start_date, c.occurrence_end_date) -%}
