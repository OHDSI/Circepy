{%- macro DemographicCriteria(c, level=0, indexLabel="cohort entry") -%}
  {%- set attrs = [] -%}
  {%- set temp = AgeGenderCriteria(age_at_start=c.age, gender=c.gender, gender_cs=c.gender_cs) -%}
  {%- if temp -%}{%- set _ = attrs.append(temp) -%}{%- endif -%}
  
  {%- set temp = EventDateCriteria(c.occurrence_start_date, c.occurrence_end_date) -%}
  {%- if temp -%}{%- set _ = attrs.append(temp) -%}{%- endif -%}
  
  {%- if c.race -%}
    {%- set temp -%}race is: {{ inputTypes.ConceptList(c.race) }}{%- endset -%}
    {%- set _ = attrs.append(temp) -%}
  {%- endif -%}
  
  {%- if c.ethnicity -%}
    {%- set temp -%}ethnicity is: {{ inputTypes.ConceptList(c.ethnicity) }}{%- endset -%}
    {%- set _ = attrs.append(temp) -%}
  {%- endif -%}
  
  {%- if attrs|length > 0 -%}
    with the following event criteria: {{ attrs|join("; ") }}.
  {%- else -%}
    any event (no demographic criteria specified).
  {%- endif -%}
{%- endmacro -%}

{%- macro ConditionOccurrence(c, level, isPlural=true, countCriteria={}, indexLabel="cohort entry") -%}
