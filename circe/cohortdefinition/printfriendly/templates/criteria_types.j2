  {%- set temp = EventDateCriteria(c.occurrence_start_date, c.occurrence_end_date) -%}
  {%- if temp -%}{%- set _ = attrs.append(temp) -%}{%- endif -%}
  
  {%- if c.condition_type is not none -%}
    {%- set temp -%}a condition type that{% if c.condition_type_exclude %} is not:{% else %} is:{% endif %} {{ inputTypes.ConceptList(c.condition_type) }}{%- endset -%}
    {%- set _ = attrs.append(temp) -%}
  {%- endif -%}
  
  {%- if c.condition_type_cs and c.condition_type_cs.codeset_id is not none -%}
