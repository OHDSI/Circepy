{# 
  Domain criteria rendering templates
  Direct port from Java's criteriaTypes.ftl
#}

{%- import 'input_types.j2' as inputTypes -%}
{%- import 'utils.j2' as utils -%}

{# ============================================
   Criteria Dispatcher
   ============================================ #}
{%- macro Criteria(c, level=0, isPlural=true, countCriteria={}, indexLabel="cohort entry") -%}
  {%- set type_name = c.__class__.__name__ -%}
  {%- set custom_template = get_template_for_criteria(c) -%}
  {%- if custom_template -%}
    {%- with criteria=c, level=level, isPlural=isPlural, countCriteria=countCriteria, indexLabel=indexLabel -%}
      {%- include custom_template -%}
    {%- endwith -%}
  {%- elif type_name == "ConditionEra" -%}{{ ConditionEra(c, level, isPlural, countCriteria, indexLabel) }}
  {%- elif type_name == "ConditionOccurrence" -%}{{ ConditionOccurrence(c, level, isPlural, countCriteria, indexLabel) }}
  {%- elif type_name == "Death" -%}{{ Death(c, level, isPlural, countCriteria, indexLabel) }}
  {%- elif type_name == "DeviceExposure" -%}{{ DeviceExposure(c, level, isPlural, countCriteria, indexLabel) }}
  {%- elif type_name == "DoseEra" -%}{{ DoseEra(c, level, isPlural, countCriteria, indexLabel) }}
  {%- elif type_name == "DrugEra" -%}{{ DrugEra(c, level, isPlural, countCriteria, indexLabel) }}
  {%- elif type_name == "DrugExposure" -%}{{ DrugExposure(c, level, isPlural, countCriteria, indexLabel) }}
  {%- elif type_name == "LocationRegion" -%}{{ LocationRegion(c, level, isPlural, countCriteria, indexLabel) }}
  {%- elif type_name == "Measurement" -%}{{ Measurement(c, level, isPlural, countCriteria, indexLabel) }}
  {%- elif type_name == "Observation" -%}{{ Observation(c, level, isPlural, countCriteria, indexLabel) }}
  {%- elif type_name == "ObservationPeriod" -%}{{ ObservationPeriod(c, level, isPlural, countCriteria, indexLabel) }}
  {%- elif type_name == "ProcedureOccurrence" -%}{{ ProcedureOccurrence(c, level, isPlural, countCriteria, indexLabel) }}
  {%- elif type_name == "Specimen" -%}{{ Specimen(c, level, isPlural, countCriteria, indexLabel) }}
  {%- elif type_name == "VisitOccurrence" -%}{{ VisitOccurrence(c, level, isPlural, countCriteria, indexLabel) }}
  {%- elif type_name == "VisitDetail" -%}{{ VisitDetail(c, level, isPlural, countCriteria, indexLabel) }}
  {%- else -%}Unknown criteria type: {{ type_name }}
  {%- endif -%}
{%- endmacro -%}

{# ============================================
   Common Helpers
   ============================================ #}

{%- macro AgeGenderCriteria(age_at_start=none, gender=none, gender_cs=none, age_at_end=none) -%}
  {%- if (age_at_start and age_at_start.op) or (age_at_end and age_at_end.op) or (gender and gender|length > 0) or (gender_cs and gender_cs.codeset_id is not none) -%}
    who are
    {%- if gender and gender|length > 0 -%}
      {{ " " }}{{ inputTypes.ConceptList(gender, quote="") }}{% if ((age_at_start and age_at_start.op) or (age_at_end and age_at_end.op)) and gender|length > 1 %},{% endif %}
    {%- elif gender_cs and gender_cs.codeset_id is not none -%}
      {{ " " }}gender {{ inputTypes.ConceptSetSelection(gender_cs) }}{% if (age_at_start and age_at_start.op) or (age_at_end and age_at_end.op) %}{{ "," if gender_cs.is_excluded else "" }} {% endif %}
    {%- endif -%}
    {%- if age_at_start and age_at_start.op -%}
      {{ " " }}{{ inputTypes.NumericRange(age_at_start) }} years old{% if age_at_end and age_at_end.op %} at era start and{% endif %}
    {%- endif -%}
    {%- if age_at_end and age_at_end.op -%}
      {{ " " }}{{ inputTypes.NumericRange(age_at_end) }} years old at era end
    {%- endif -%}
  {%- endif -%}
{%- endmacro -%}

{%- macro EventDateCriteria(startRange=none, endRange=none) -%}
  {%- if startRange and startRange.op and endRange and endRange.op -%}
    starting {{ inputTypes.DateRange(startRange) }} and ending {{ inputTypes.DateRange(endRange) }}
  {%- elif startRange and startRange.op -%}
    starting {{ inputTypes.DateRange(startRange) }}
  {%- elif endRange and endRange.op -%}
    ending {{ inputTypes.DateRange(endRange) }}
  {%- endif -%}
{%- endmacro -%}

{%- macro WindowCriteria(countCriteria, indexLabel="cohort entry", level=0) -%}
  {%- set windowParts = [] -%}
  {%- set restrictParts = [] -%}
  
  {%- if countCriteria.start_window and (countCriteria.start_window.start.days is not none or countCriteria.start_window.end.days is not none) -%}
    {%- set _ = windowParts.append(inputTypes.Window(countCriteria.start_window, indexLabel)) -%}
  {%- endif -%}
  
  {%- if countCriteria.end_window and (countCriteria.end_window.start.days is not none or countCriteria.end_window.end.days is not none) -%}
    {%- set _ = windowParts.append(inputTypes.Window(countCriteria.end_window, indexLabel)) -%}
  {%- endif -%}
  
  {%- if countCriteria.restrict_visit -%}
    {%- set _ = restrictParts.append("at same visit as " ~ indexLabel) -%}
  {%- endif -%}
  
  {%- if countCriteria.ignore_observation_period -%}
    {%- set _ = restrictParts.append("allow events outside observation period") -%}
  {%- endif -%}
  
  {%- if windowParts|length > 0 -%}
    {{ windowParts|join(" and ") }}
    {%- if restrictParts|length > 0 -%}; {% endif -%}
  {%- endif -%}
  
  {%- if restrictParts|length > 0 -%}
    {{ restrictParts|join(" and ") }}
  {%- endif -%}
{%- endmacro -%}

{# ============================================
   Simple Criteria
   ============================================ #}

{%- macro Death(c, level, isPlural=true, countCriteria={}, indexLabel="cohort entry") -%}
  {%- set attrs = [] -%}
  {%- if countCriteria and countCriteria.occurrence -%}
    {%- set temp = WindowCriteria(countCriteria, indexLabel) -%}
    {%- if temp -%}{%- set _ = attrs.append(temp) -%}{%- endif -%}
  {%- endif -%}
  
  {%- set temp = AgeGenderCriteria(age_at_start=c.age, gender=c.gender, gender_cs=c.gender_cs) -%}
  {%- if temp -%}{%- set _ = attrs.append(temp) -%}{%- endif -%}
  
  {%- set temp = inputTypes.DateAdjustment(c.date_adjustment) -%}
  {%- if temp -%}{%- set _ = attrs.append(temp) -%}{%- endif -%}
  
  {%- set temp = EventDateCriteria(c.occurrence_start_date, c.occurrence_end_date) -%}
  {%- if temp -%}{%- set _ = attrs.append(temp) -%}{%- endif -%}
  
  {%- if c.death_type -%}
    {%- set temp -%}a death type that{% if c.death_type_exclude %} is not:{% else %} is:{% endif %} {{ inputTypes.ConceptList(c.death_type) }}{%- endset -%}
    {%- set _ = attrs.append(temp) -%}
  {%- endif -%}
  
  {%- if c.death_type_cs and c.death_type_cs.codeset_id is not none -%}
    {%- set temp -%}a death type concept {{ inputTypes.ConceptSetSelection(c.death_type_cs) }} concept set{%- endset -%}
    {%- set _ = attrs.append(temp) -%}
  {%- endif -%}
  
  death of {{ codeset_name(c.codeset_id, "any form") -}}
  {% if c.death_source_concept is not none %} (including {{ codeset_name(c.death_source_concept, "any form") }} source concepts){% endif -%}
  {%- if attrs|length > 0 -%}, {{ attrs|join("; ") }}{%- endif -%}
  {%- if c.correlated_criteria -%}; {{ Group(c.correlated_criteria, level, indexLabel=codeset_name(c.codeset_id, "any form")) }}{%- else -%}.{%- endif -%}
{%- endmacro -%}

{%- macro LocationRegion(c, level, isPlural=true, countCriteria={}, indexLabel="cohort entry") -%}
  {%- set attrs = [] -%}
  {%- if countCriteria and countCriteria.occurrence -%}
    {%- set temp = WindowCriteria(countCriteria, indexLabel) -%}
    {%- if temp -%}{%- set _ = attrs.append(temp) -%}{%- endif -%}
  {%- endif -%}
  
  {%- set temp = EventDateCriteria(c.start_date, c.end_date) -%}
  {%- if temp -%}{%- set _ = attrs.append(temp) -%}{%- endif -%}
  
  location of {{ codeset_name(c.codeset_id, "any location") }}
  {%- if attrs|length > 0 -%}, {{ attrs|join("; ") }}{%- endif -%}
  {%- if c.correlated_criteria -%}; {{ Group(c.correlated_criteria, level, indexLabel=codeset_name(c.codeset_id, "any location")) }}{%- else -%}.{%- endif -%}
{%- endmacro -%}

{# ============================================
   Group and Count Infrastructure
   ============================================ #}

{%- macro GroupHeader(group) -%}
  with {% if group.type == "ALL" %}all{% elif group.type == "ANY" %}any{% elif group.type == "AT_LEAST" %}at least {{ group.count }}{% elif group.type == "AT_MOST" %}at most {{ group.count }}{% else %}{{ group.type }}{% endif %} of the following criteria:
{%- endmacro -%}

{%- macro Group(group, parentGroup=none, isFirst=true, indexLabel="cohort entry", level=0) -%}
  {%- set demo_size = group.demographic_criteria_list|length if group.demographic_criteria_list else 0 -%}
  {%- set crit_size = group.criteria_list|length if group.criteria_list else 0 -%}
  {%- set group_size = group.groups|length if group.groups else 0 -%}
  
  {%- if (demo_size + crit_size) > 1 or group.type not in ["ANY", "ALL"] or group_size > 0 -%}
    {{ GroupHeader(group) }}
    {%- if group.demographic_criteria_list -%}
      {%- for demoCriteria in group.demographic_criteria_list %}

{{ utils.indent(level + 1) }}{{ loop.index }}. {{ DemographicCriteria(demoCriteria, level + 1, indexLabel) }}
      {%- endfor -%}
    {%- endif -%}
    {%- if group.criteria_list -%}
      {%- for countCriteria in group.criteria_list %}

{{ utils.indent(level + 1) }}{{ demo_size + loop.index }}. {{ CountCriteria(countCriteria, level + 1, indexLabel) }}
      {%- endfor -%}
    {%- endif -%}
    {%- if group.groups -%}
      {%- for subgroup in group.groups %}

{{ utils.indent(level + 1) }}{{ demo_size + crit_size + loop.index }}. {{ Group(subgroup, group, (loop.index == 1 and crit_size == 0 and demo_size == 0), indexLabel, level + 1) }}
      {%- endfor -%}
    {%- endif -%}
  {%- else -%}
    {%- if crit_size == 1 -%}{{ CountCriteria(group.criteria_list[0], level, indexLabel) }}{%- endif -%}
    {%- if demo_size == 1 -%}{{ DemographicCriteria(group.demographic_criteria_list[0], level, indexLabel) }}{%- endif -%}
  {%- endif -%}
{%- endmacro -%}

{%- macro CountCriteria(countCriteria, level=0, indexLabel="cohort entry") -%}
  having
  {%- if countCriteria.occurrence.type == 0 and countCriteria.occurrence.count == 0 -%}
    {{ " " }}no
  {%- else -%}
    {{ " " }}{% if countCriteria.occurrence.type == 0 %}exactly
    {%- elif countCriteria.occurrence.type == 1 %}at most
    {%- elif countCriteria.occurrence.type == 2 %}at least
    {%- endif %} {{ countCriteria.occurrence.count }}
  {%- endif -%}
  {%- if countCriteria.occurrence.is_distinct -%}
    {{ " " }}distinct {{ utils.count_column(countCriteria.occurrence.count_column or "DOMAIN_CONCEPT") }} from
  {%- endif %} {{ Criteria(countCriteria.criteria, level, (countCriteria.occurrence.count != 1), countCriteria, indexLabel) }}
{%- endmacro -%}

{# ============================================
   Placeholders for other criteria
   ============================================ #}

{%- macro ConditionEra(c, level=0, isPlural=true, countCriteria={}, indexLabel="cohort entry") -%}
  {%- set attrs = [] -%}
  {%- if countCriteria and countCriteria.occurrence -%}
    {%- set temp = WindowCriteria(countCriteria, indexLabel) -%}
    {%- if temp -%}{%- set _ = attrs.append(temp) -%}{%- endif -%}
  {%- endif -%}
  
  {%- set temp = AgeGenderCriteria(age_at_start=c.age_at_start, age_at_end=c.age_at_end, gender=c.gender, gender_cs=c.gender_cs) -%}
  {%- if temp -%}{%- set _ = attrs.append(temp) -%}{%- endif -%}
  
  {%- set temp = inputTypes.DateAdjustment(c.date_adjustment) -%}
  {%- if temp -%}{%- set _ = attrs.append(temp) -%}{%- endif -%}
  
  {%- set temp = EventDateCriteria(c.era_start_date, c.era_end_date) -%}
  {%- if temp -%}{%- set _ = attrs.append(temp) -%}{%- endif -%}
  
  {%- if c.era_length -%}
    {%- set temp -%}era length is {{ inputTypes.NumericRange(c.era_length) }} days{%- endset -%}
    {%- set _ = attrs.append(temp) -%}
  {%- endif -%}
  
  {%- if c.occurrence_count -%}
    {%- set temp -%}containing {{ inputTypes.NumericRange(c.occurrence_count) }} occurrences{%- endset -%}
    {%- set _ = attrs.append(temp) -%}
  {%- endif -%}
  
  condition era{% if isPlural and not c.first %}s{% endif %} of {{ codeset_name(c.codeset_id, "any condition") }}
  {%- if c.first %} for the first time in the person's history{% endif -%}
  {%- if attrs|length > 0 -%}, {{ attrs|join("; ") }}{%- endif -%}
  {%- if c.correlated_criteria -%}; {{ Group(c.correlated_criteria, level, indexLabel=codeset_name(c.codeset_id, "any condition")) }}{%- else -%}.{%- endif -%}
{%- endmacro -%}

